@model Web_Tuan3.Models.StudentModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">ĐĂNG KÝ THÀNH CÔNG</h4>
                </div>
                <div class="card-body text-center p-5">
                    <p class="fs-5">
                        Chào <span class="fw-bold text-primary">@Model.HoTen</span> (@Model.MSSV),<br />
                        Bạn đã đăng ký thành công chuyên ngành: <br />
                        <span class="badge bg-info text-dark fs-6 mt-2">@Model.ChuyenNganh</span>
                    </p>

                    <div class="alert alert-warning border-warning mt-4">
                        <i class="bi bi-info-circle-fill"></i>
                        Hiện tại có <strong>@ViewBag.Count</strong> sinh viên đăng ký cùng ngành với bạn.
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Index" class="btn btn-outline-primary">Tiếp tục đăng ký</a>
                        <a asp-action="List" class="btn btn-success">Xem danh sách tổng</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>