@model Web_Tuan5.Models.Book

@{
    ViewData["Title"] = "Chi tiết sách";
}

<h2 class="mb-4">Chi tiết sách</h2>

<div class="row">

    <!-- ẢNH SÁCH -->
    <div class="col-md-4 text-center">

        <img src="~/ImageBooks/@Model.ImageUrl"
             class="img-fluid"
             style="max-height:400px" />

    </div>


    <!-- THÔNG TIN SÁCH -->
    <div class="col-md-8">

        <h2>@Model.Title</h2>

        <p>
            <strong>Tác giả:</strong> @Model.Author
        </p>

        <p>
            <strong>Thể loại:</strong> @Model.Category?.Name
        </p>

        <p class="text-danger fs-3">
            <strong>@Model.Price.ToString("N0") VNĐ</strong>
        </p>

        <p>
            <strong>Mô tả:</strong>
        </p>

        <p>
            @Model.Description
        </p>


        <!-- SỐ LƯỢNG -->
        <div class="mb-3">

            <label>Số lượng:</label>

            <input type="number"
                   value="1"
                   min="1"
                   class="form-control"
                   style="width:100px" />

        </div>


        <!-- BUTTON -->
        <div class="mt-3">

            <a class="btn btn-outline-danger">
                Thêm vào giỏ hàng
            </a>

            <a class="btn btn-danger">
                Mua ngay
            </a>


            <a asp-action="Index"
               class="btn btn-secondary">
                Quay lại
            </a>

        </div>

    </div>

</div>