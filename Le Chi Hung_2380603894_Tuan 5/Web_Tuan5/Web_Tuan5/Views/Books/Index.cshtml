@model IEnumerable<Web_Tuan5.Models.Book>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="row">

    <!-- SIDEBAR -->
    <div class="col-md-3">
        <h4>Chủ đề</h4>
        <ul class="list-group">
            @foreach (var c in ViewBag.Categories)
            {
                <li class="list-group-item">
                    @c.Name (@c.Count)
                </li>
            }
        </ul>
    </div>

    <!-- CONTENT -->
    <div class="col-md-9">

        <div class="d-flex justify-content-between mb-3">
            <h4>Danh sách sách</h4>
            <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card">

                        <div class="card-header d-flex justify-content-between">
                            <span>@item.Title</span>
                            <a asp-action="Edit" asp-route-id="@item.Id">
                                Edit
                            </a>
                        </div>

                        <div class="card-body text-center">

                            <img src="~/ImageBooks/@(item.ImageUrl ?? "noimage.png")"
                                 class="img-fluid"
                                 style="height:200px; object-fit:contain;" />

                            <p class="mt-2"><strong>Tác giả:</strong> @item.Author</p>
                            <p><strong>Thể loại:</strong> @item.Category?.Name</p>

                        </div>

                        <div class="card-footer text-center">
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-secondary btn-sm">
                                Chi tiết
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </div>

                    </div>
                </div>
            }
        </div>

    </div>
</div>