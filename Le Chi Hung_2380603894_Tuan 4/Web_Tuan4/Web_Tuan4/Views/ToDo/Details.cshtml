@model Web_Tuan4.Models.TodoItem

@{
    ViewData["Title"] = "Chi tiết công việc";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm border-0 p-4">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                    <h2 class="text-primary fw-bold mb-0">CHI TIẾT CÔNG VIỆC #@Model.Id</h2>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">
                        &laquo; Quay lại
                    </a>
                </div>
                
                <div class="row">
                    <div class="col-md-8">
                        <dl class="row mb-0 align-items-center">
                            <dt class="col-sm-4 text-muted text-uppercase small fw-normal">Tên công việc</dt>
                            <dd class="col-sm-8 fs-5 fw-semibold text-dark">@Model.TenCongViec</dd>
                            
                            <dt class="col-sm-4 text-muted text-uppercase small fw-normal mt-3">Trạng thái</dt>
                            <dd class="col-sm-8 mt-3">
                                @if (Model.IsHoanThanh)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2">Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning px-3 py-2">Đang chờ</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-4 text-center text-md-end mt-4 mt-md-0 d-flex flex-column gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg rounded-pill px-4">
                            <i class="bi bi-pencil-fill"></i> Chỉnh sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm rounded-pill px-4 mt-2">
                            Xóa công việc
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>