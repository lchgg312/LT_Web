@model Web_Tuan4.Models.TodoItem

@{
    ViewData["Title"] = "Xóa công việc";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5 text-center">
                    <div class="mb-4 text-danger">
                        <i class="bi bi-exclamation-octagon-fill" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="text-danger fw-bold mb-3">XÓA CÔNG VIỆC?</h2>
                    <p class="text-muted mb-4 fs-5">
                        Bạn có chắc chắn muốn xóa công việc <br />
                        <span class="fw-bold text-dark">#@Model.Id - @Model.TenCongViec</span>?
                    </p>
                    <p class="text-warning small mb-5">Hành động này không thể hoàn tác.</p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5">Xác nhận xóa</button>
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>